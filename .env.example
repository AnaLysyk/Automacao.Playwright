# Visão geral dos ambientes e contexto funcional
# TARGET_ENV define o ambiente de execução.
# - 146: homologação / desenvolvimento / QA em construção
# - 201: ambiente próximo de produção / validações conservadoras
# - 200: ambiente GBDS/MIR complementar
#
# Use .env.local para variáveis sensíveis e locais.
# Não versionar senhas, tokens ou credenciais.
#
# Exemplo de seleções por ambiente:
# TARGET_ENV=146
# CIDADAO_SMART_BASE_URL=https://172.16.1.146
# BOOKING_ADMIN_BASE_URL=https://172.16.1.146/admin/login
# SMART_BASE_URL=https://172.16.1.146:8100/react
#
# TARGET_ENV=201
# CIDADAO_SMART_BASE_URL=https://172.16.1.201
# BOOKING_ADMIN_BASE_URL=https://172.16.1.201/admin/login
# SMART_BASE_URL=https://172.16.1.201:8100/react
#
TARGET_ENV=146

# URL base do ambiente Cidadão Smart.
CIDADAO_SMART_BASE_URL=https://172.16.1.146
SMART_REACT_URL=http://172.16.1.146:8100/react

# Modo de tratamento do CAPTCHA.
# manual: pausa a execução para intervenção humana.
# disabled: usado somente se o ambiente QA estiver sem CAPTCHA.
# test: reservado para chave/modo de teste.
CAPTCHA_MODE=manual

# Código de segurança temporário para fluxos com autenticação por e-mail.
# Não preencher com código real no repositório.
CIDADAO_SMART_SECURITY_CODE=

# Fonte do código de segurança:
# env  -> usa CIDADAO_SMART_SECURITY_CODE
# imap -> busca automaticamente na caixa de e-mail via IMAP
CIDADAO_SMART_SECURITY_CODE_SOURCE=env

# Configuração IMAP (usada quando CIDADAO_SMART_SECURITY_CODE_SOURCE=imap)
CIDADAO_SMART_EMAIL_IMAP_HOST=
CIDADAO_SMART_EMAIL_IMAP_PORT=993
CIDADAO_SMART_EMAIL_IMAP_SECURE=true
CIDADAO_SMART_EMAIL_IMAP_USER=
CIDADAO_SMART_EMAIL_IMAP_PASSWORD=
CIDADAO_SMART_EMAIL_IMAP_MAILBOX=INBOX
CIDADAO_SMART_EMAIL_FROM_FILTER=
CIDADAO_SMART_EMAIL_CODE_REGEX=\b(\d{6})\b
CIDADAO_SMART_EMAIL_POLL_TIMEOUT_MS=120000
CIDADAO_SMART_EMAIL_POLL_INTERVAL_MS=5000

# E-mail de teste usado nos fluxos.
CIDADAO_SMART_TEST_EMAIL=qa-booking@example.com

# Evita confirmação real em demonstrações.
CIDADAO_SMART_DRY_RUN=true

# Dados padrão da demonstração.
CIDADAO_SMART_DEFAULT_CITY=Florianópolis
CIDADAO_SMART_DEFAULT_SERVICE_POINT=PCI - FLORIANÓPOLIS - Top Tower
CIDADAO_SMART_DEFAULT_SERVICE_POINT_ID=top-tower
CIDADAO_SMART_TEST_NAME=Automacao Assistida
CIDADAO_SMART_TEST_CPF=
CIDADAO_SMART_TEST_PHONE=(55) 55555-5555
CIDADAO_SMART_TEST_APPOINTMENT_DATE=
CIDADAO_SMART_TEST_APPOINTMENT_TIME=08:00
BOOKING_ALLOW_FIRST_AVAILABLE_DATE=true
BOOKING_ALLOW_FIRST_AVAILABLE_TIME=true

# Arquivo usado no fluxo de upload de foto.
CIDADAO_SMART_VALID_PHOTO_PATH=tests/support/files/valid-photo.jpg

# Dados opcionais para autenticação/consulta.
CIDADAO_SMART_EMISSAO_TEST_NOME=
CIDADAO_SMART_EMISSAO_TEST_NOME_MAE=
CIDADAO_SMART_TEST_BIRTH_DATE=
CIDADAO_SMART_TEST_PROTOCOL=
CIDADAO_SMART_TEST_APPOINTMENT_PROTOCOL=

# ============================================================================
# BOOKING/ADMIN - PAINEL ADMINISTRATIVO
# ============================================================================
# URL base do Booking/Admin
BOOKING_ADMIN_BASE_URL=https://172.16.1.146/admin/login

# Credenciais do admin
# ⚠️ NUNCA incluir senha real aqui. Use .env.local na sua máquina.
BOOKING_ADMIN_USER=
BOOKING_ADMIN_PASSWORD=

# Intervalo de pausa para visualização em testes do Admin
BOOKING_ADMIN_VISUAL_PAUSE_MS=1000

# ============================================================================
# SMART INTERNO - PROCESSAMENTO E CONFERÊNCIA
# ============================================================================
# URL base do SMART interno
SMART_BASE_URL=http://172.16.1.146:8100/react

# Credenciais do SMART
# ⚠️ NUNCA incluir senha real aqui. Use .env.local na sua máquina.
SMART_USER=
SMART_PASSWORD=

# ============================================================================
# APIs E INTEGRAÇÕES
# ============================================================================
# CPF do operador (obrigatório em headers x-operator-cpf)
X_OPERATOR_CPF=

# Keycloak / Autenticação Central
KEYCLOAK_TOKEN_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Notificador GBDS (webhook)
GBDS_WEBHOOK_URL=
GBDS_API_KEY=

# DAE (Documento de Arrecadação Estadual)
DAE_API_URL=
DAE_API_KEY=

# ============================================================================
# CONFIGURAÇÕES GERAIS DE TESTE
# ============================================================================
# Modo de execução: 'manual-assisted' (pausa e interação manual), 'local' (com pausa), 'ci' (headless)
EXECUTION_MODE=manual-assisted
PW_SLOW_MO=300

# Navegador: 'chromium', 'firefox', 'webkit'
BROWSER=chromium

# Timeouts (ms)
NAVIGATION_TIMEOUT=30000
API_TIMEOUT=15000

# Debug: 'true' para logs detalhados
DEBUG_MODE=false

# Estratégia de massa de dados:
#   - 'preferida'  : Tenta horário/data preferido, depois fallback
#   - 'primeira'   : Sempre primeira opção disponível
#   - 'qualquer'   : Qualquer data/horário serve
SCHEDULING_STRATEGY=preferida

# Horário preferido (HH:mm)
PREFERRED_TIME=09:00

# ============================================================================
# HARDWARE (Captura Biométrica)
# ============================================================================
# Ativar testes com hardware real (câmera, leitor)
BCC_ENABLED=false

# Porta serial do leitor biométrico
BCC_PORT=COM3
BCC_BAUD_RATE=115200

# ============================================================================
# RELATÓRIOS
# ============================================================================
# Screenshot em cada falha
SCREENSHOT_ON_FAILURE=true

# Trace (mais pesado, para debug profundo)
TRACE_ON_FAILURE=false

# Diretório de logs
LOG_DIR=./test-results

# ============================================================================
# CI/CD
# ============================================================================
# Preenchidos automaticamente pelo pipeline (GitLab CI, GitHub Actions, etc.)
CI_BUILD_ID=
CI_PIPELINE_ID=
CI_COMMIT_SHA=
CI_COMMIT_REF_NAME=main

# Controle explícito para submissão final (mantém seguro por padrão).
CIDADAO_SMART_ALLOW_FINAL_SUBMIT=false
