# Ambiente alvo
# 146: desenvolvimento/homologacao
# 201: producao ou producao-like, usar com cautela e priorizar read-only
TARGET_ENV=146

# URLs principais
CIDADAO_SMART_BASE_URL=https://172.16.1.146
BOOKING_ADMIN_BASE_URL=https://172.16.1.146/admin/login
SMART_REACT_URL=http://172.16.1.146:8100/react
SMART_BASE_URL=http://172.16.1.146:8100/react

# Execucao
CAPTCHA_MODE=manual
EXECUTION_MODE=manual-assisted
PW_SLOW_MO=300
EVIDENCE_DIR=test-results
PROTOCOL_REPORT_PATH=.runtime/protocolos-gerados.json
CIDADAO_SMART_DRY_RUN=true

# Captura / camera
CAPTURE_MODE=manual
CAMERA_FAKE_IMAGE_PATH=
CAMERA_FAKE_VIDEO_PATH=
CAMERA_FAKE_VIDEO_SECONDS=5
CAMERA_FAKE_VIDEO_SIZE=640x480

# Codigo de seguranca por e-mail
# manual: pessoa digita o codigo
# env: usa CIDADAO_SMART_SECURITY_CODE local
# imap: captura codigo da caixa de teste autorizada
# gmail-api/internal-api/log: reservados para integracoes controladas
EMAIL_CODE_MODE=manual
CIDADAO_SMART_SECURITY_CODE=
CIDADAO_SMART_SECURITY_CODE_SOURCE=env

# Massa controlada
# Preencher dados reais ou sensiveis apenas em .env.local.
CIDADAO_SMART_DEFAULT_CITY=Florianopolis
CIDADAO_SMART_DEFAULT_SERVICE_POINT=PCI - FLORIANOPOLIS - Top Tower
CIDADAO_SMART_DEFAULT_SERVICE_POINT_ID=top-tower
CIDADAO_SMART_TEST_NAME=Automacao Assistida
CIDADAO_SMART_TEST_CPF=
CIDADAO_SMART_TEST_CPF_FORMATTED=
CIDADAO_SMART_TEST_BIRTH_DATE=01/01/2001
CIDADAO_SMART_TEST_EMAIL=qa-cidadao-smart@example.com
CIDADAO_SMART_TEST_PHONE=(55) 55555-55555
CIDADAO_SMART_TEST_PHONE_RAW=55555555555
CIDADAO_SMART_TEST_APPOINTMENT_DATE=
CIDADAO_SMART_TEST_APPOINTMENT_TIME=08:00
BOOKING_ALLOW_FIRST_AVAILABLE_DATE=true
BOOKING_ALLOW_FIRST_AVAILABLE_TIME=true

# Massa controlada 2 via
# Informar CPF/data de CIN finalizada somente em .env.local.
CIDADAO_SMART_2VIA_FINALIZADA_CPF=
CIDADAO_SMART_2VIA_FINALIZADA_NASCIMENTO=
CIDADAO_SMART_2VIA_EXPRESSA_CPF=
CIDADAO_SMART_2VIA_EXPRESSA_NOME=Automacao 2 Via Expressa
CIDADAO_SMART_2VIA_EXPRESSA_NOME_MAE=Automacao Mae 2 Via Expressa
CIDADAO_SMART_2VIA_EXPRESSA_NASCIMENTO=
CIDADAO_SMART_2VIA_EXPRESSA_EMAIL=qa-cidadao-smart@example.com
CIDADAO_SMART_2VIA_EXPRESSA_TELEFONE=
CIDADAO_SMART_2VIA_ALTERACOES_CPF=
CIDADAO_SMART_2VIA_ALTERACOES_NOME=Automacao 2 Via Alteracoes
CIDADAO_SMART_2VIA_ALTERACAO_NOME_NOVO=Automacao Nome Alterado
CIDADAO_SMART_2VIA_ALTERACOES_NOME_MAE=Automacao Mae 2 Via Alteracoes
CIDADAO_SMART_2VIA_ALTERACOES_NASCIMENTO=
CIDADAO_SMART_MENOR_16_CPF=
CIDADAO_SMART_MENOR_16_NOME=Automacao Menor 16
CIDADAO_SMART_MENOR_16_NOME_MAE=Automacao Mae Menor 16
CIDADAO_SMART_MENOR_16_NASCIMENTO=
CIDADAO_SMART_MENOR_16_TELEFONE=
CIDADAO_SMART_MENOR_16_EMAIL=
CIDADAO_SMART_INELEGIVEL_CPF=
CIDADAO_SMART_INELEGIVEL_NOME=
CIDADAO_SMART_INELEGIVEL_NASCIMENTO=
CIDADAO_SMART_INELEGIVEL_TELEFONE=
CIDADAO_SMART_INELEGIVEL_EMAIL=
CIDADAO_SMART_PROCESSO_DUPLICADO_CPF=
CIDADAO_SMART_PROCESSO_DUPLICADO_NOME=
CIDADAO_SMART_PROCESSO_DUPLICADO_NASCIMENTO=

# Credenciais locais, nao preencher no repositorio
BOOKING_ADMIN_USER=
BOOKING_ADMIN_PASSWORD=
SMART_USER=
SMART_PASSWORD=

# SMART write / finalizacao assistida
# Ligar somente em ambiente controlado, pois altera estado de processo.
SMART_WRITE_ENABLED=false
SMART_SEND_BIOMETRICS_ENABLED=true
SMART_AUTOFILL_JSON_PATH=
SMART_FINALIZED_MAX_RESUMES=5

# API
API_BASE_URL=
API_TOKEN=
KEYCLOAK_TOKEN_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
X_OPERATOR_CPF=

# Integracoes
GBDS_WEBHOOK_URL=
GBDS_WRITE_ENABLED=false
GBDS_API_KEY=
DAE_API_URL=
DAE_API_KEY=

# Gmail API / OAuth para caixa de teste
GMAIL_TEST_ACCOUNT=
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
GMAIL_CODE_QUERY=from:noreply newer_than:10m
GMAIL_CODE_REGEX=\b\d{6}\b

# E-mail QA / codigo de seguranca por IMAP
# Criar caixa dedicada, por exemplo qa-cidadao-smart@seudominio.
# Preencher host/usuario/senha apenas no .env.local.
CIDADAO_SMART_EMAIL_IMAP_HOST=
CIDADAO_SMART_EMAIL_IMAP_PORT=993
CIDADAO_SMART_EMAIL_IMAP_SECURE=true
CIDADAO_SMART_EMAIL_IMAP_USER=
CIDADAO_SMART_EMAIL_IMAP_PASSWORD=
CIDADAO_SMART_EMAIL_IMAP_MAILBOX=INBOX
CIDADAO_SMART_EMAIL_FROM_FILTER=
CIDADAO_SMART_EMAIL_CODE_REGEX=\b(\d{6})\b
CIDADAO_SMART_EMAIL_POLL_TIMEOUT_MS=120000
CIDADAO_SMART_EMAIL_POLL_INTERVAL_MS=5000

# Seguranca operacional
CIDADAO_SMART_ALLOW_FINAL_SUBMIT=false
