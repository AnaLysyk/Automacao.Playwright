# Ambiente alvo
# 146: desenvolvimento/homologação
# 201: produção ou produção-like, usar com cautela e priorizar read-only
TARGET_ENV=146

# URLs principais
CIDADAO_SMART_BASE_URL=https://172.16.1.146
BOOKING_ADMIN_BASE_URL=https://172.16.1.146/admin/login
SMART_REACT_URL=http://172.16.1.146:8100/react
SMART_BASE_URL=http://172.16.1.146:8100/react

# Execução
CAPTCHA_MODE=manual
EXECUTION_MODE=manual-assisted
PW_SLOW_MO=300
EVIDENCE_DIR=test-results

# Código de segurança
# Não preencher com código real no repositório.
CIDADAO_SMART_SECURITY_CODE=
CIDADAO_SMART_SECURITY_CODE_SOURCE=env

# Massa controlada
# Preencher dados reais ou sensíveis apenas em .env.local.
CIDADAO_SMART_DEFAULT_CITY=Florianópolis
CIDADAO_SMART_DEFAULT_SERVICE_POINT=PCI - FLORIANÓPOLIS - Top Tower
CIDADAO_SMART_DEFAULT_SERVICE_POINT_ID=top-tower
CIDADAO_SMART_TEST_NAME=Automacao Assistida
CIDADAO_SMART_TEST_CPF=
CIDADAO_SMART_TEST_CPF_FORMATTED=
CIDADAO_SMART_TEST_BIRTH_DATE=01/01/1990
CIDADAO_SMART_TEST_EMAIL=qa-booking@example.com
CIDADAO_SMART_TEST_PHONE=(55) 55555-5555
CIDADAO_SMART_TEST_PHONE_RAW=55555555555
CIDADAO_SMART_TEST_APPOINTMENT_DATE=
CIDADAO_SMART_TEST_APPOINTMENT_TIME=08:00
BOOKING_ALLOW_FIRST_AVAILABLE_DATE=true
BOOKING_ALLOW_FIRST_AVAILABLE_TIME=true
CIDADAO_SMART_DRY_RUN=true

# Massa controlada 2ª via
CIDADAO_SMART_2VIA_EXPRESSA_CPF=
CIDADAO_SMART_2VIA_EXPRESSA_NOME=
CIDADAO_SMART_2VIA_EXPRESSA_NOME_MAE=
CIDADAO_SMART_2VIA_EXPRESSA_NASCIMENTO=
CIDADAO_SMART_2VIA_ALTERACOES_CPF=
CIDADAO_SMART_2VIA_ALTERACOES_NOME=
CIDADAO_SMART_2VIA_ALTERACOES_NOME_MAE=
CIDADAO_SMART_2VIA_ALTERACOES_NASCIMENTO=
CIDADAO_SMART_MENOR_16_CPF=
CIDADAO_SMART_MENOR_16_NOME=
CIDADAO_SMART_MENOR_16_NASCIMENTO=
CIDADAO_SMART_MENOR_16_TELEFONE=
CIDADAO_SMART_MENOR_16_EMAIL=
CIDADAO_SMART_INELEGIVEL_CPF=
CIDADAO_SMART_INELEGIVEL_NOME=
CIDADAO_SMART_INELEGIVEL_NASCIMENTO=
CIDADAO_SMART_INELEGIVEL_TELEFONE=
CIDADAO_SMART_INELEGIVEL_EMAIL=
CIDADAO_SMART_PROCESSO_DUPLICADO_CPF=
CIDADAO_SMART_PROCESSO_DUPLICADO_NOME=
CIDADAO_SMART_PROCESSO_DUPLICADO_NASCIMENTO=

# Credenciais locais, não preencher no repositório
BOOKING_ADMIN_USER=
BOOKING_ADMIN_PASSWORD=
SMART_USER=
SMART_PASSWORD=

# API
API_BASE_URL=
API_TOKEN=
KEYCLOAK_TOKEN_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
X_OPERATOR_CPF=

# Integrações
GBDS_WEBHOOK_URL=
GBDS_API_KEY=
DAE_API_URL=
DAE_API_KEY=

# E-mail / código de segurança por integração futura
CIDADAO_SMART_EMAIL_IMAP_HOST=
CIDADAO_SMART_EMAIL_IMAP_PORT=993
CIDADAO_SMART_EMAIL_IMAP_SECURE=true
CIDADAO_SMART_EMAIL_IMAP_USER=
CIDADAO_SMART_EMAIL_IMAP_PASSWORD=
CIDADAO_SMART_EMAIL_IMAP_MAILBOX=INBOX
CIDADAO_SMART_EMAIL_FROM_FILTER=
CIDADAO_SMART_EMAIL_CODE_REGEX=\b(\d{6})\b
CIDADAO_SMART_EMAIL_POLL_TIMEOUT_MS=120000
CIDADAO_SMART_EMAIL_POLL_INTERVAL_MS=5000

# Segurança operacional
CIDADAO_SMART_ALLOW_FINAL_SUBMIT=false
