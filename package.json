{
  "name": "griaule-playwright",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:list": "playwright test --list",
    "test:cidadao-smart": "playwright test tests/cidadao-smart --project=chromium",
    "test:booking": "playwright test tests/booking --project=chromium",
    "test:headed": "playwright test --headed --project=chromium",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug --project=chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.7.0",
    "dotenv": "^16.6.1",
    "imapflow": "^1.3.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
