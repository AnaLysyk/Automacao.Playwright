{
  "name": "griaule-playwright",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:list": "playwright test --list",
    "test:booking:assistido": "playwright test tests/booking/agendamento-presencial/agendamento-presencial.spec.ts --headed --project=chromium",
    "test:booking": "playwright test tests/booking --headed --project=chromium",
    "test:cidadao": "playwright test tests/cidadao-smart --headed --project=chromium",
    "test:api": "playwright test tests/api --project=chromium",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.7.0",
    "dotenv": "^16.6.1",
    "imapflow": "^1.3.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
