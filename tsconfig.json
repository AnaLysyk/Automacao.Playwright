{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "types": ["node", "@playwright/test"],
    "lib": ["ES2022", "DOM"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@support/*": ["./support/*"],
      "@tests/*": ["./tests/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": [
    "playwright.config.ts",
    "support/**/*.ts",
    "tests/**/*.ts"
  ]
}
